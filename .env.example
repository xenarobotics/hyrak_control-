# Copy this to .env and fill in values
# Never commit .env to git

# Server
SECRET_TOKEN=change_this_to_a_random_string
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# CORS — comma separated origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Vision
DEFAULT_YOLO_MODEL=yolov8n.pt
INFERENCE_RESIZE_WIDTH=640
MAX_CONCURRENT_SESSIONS=4

# GPU — leave blank to auto-detect
# CUDA_VISIBLE_DEVICES=0
# FORCE_CPU=false

# Telemetry
DEFAULT_BAUD_RATE=57600
MAVSDK_SERVER_HOST=localhost
MAVSDK_SERVER_PORT=50051

# PX4 SITL (for development)
SITL_ADDRESS=udp://:14540

# Local Postgres (Supabase/RDS later = just change this URL)
DATABASE_URL=postgresql+asyncpg://hyrak:hyrak_dev@127.0.0.1:5432/hyrak
